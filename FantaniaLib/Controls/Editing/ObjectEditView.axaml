<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FantaniaLib.ObjectEditView"
             x:Name="Root">
  <ItemsControl Grid.Row="1" ItemsSource="{Binding #Root.EditableFields}" Margin="0 10 0 0">
    <ItemsControl.ItemTemplate>
      <DataTemplate x:DataType="lib:GroupedEditableFields">
        <Grid RowDefinitions="auto,*" Margin="0 5 0 0">
          <TextBlock Grid.Row="0" Classes="m" Text="{Binding Group, Converter={StaticResource Cvt_Localization}}" Padding="5" Background="#ff286959" IsVisible="{Binding Group, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <lib:EditFieldsView Grid.Row="1" DataContext="{Binding Fields}" TooltipConverter="{StaticResource Cvt_Localization}" />
        </Grid>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
