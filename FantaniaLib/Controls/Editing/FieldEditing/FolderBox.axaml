<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="lib:IEditableField"
             x:Class="FantaniaLib.FolderBox"
             x:Name="Root">
  <Grid>
    <Grid ColumnDefinitions="*,auto">
      <TextBox Grid.Column="0" Text="{Binding FieldValue, Mode=TwoWay}" AcceptsReturn="False" VerticalAlignment="Center" ToolTip.ServiceEnabled="{Binding FieldValidator.Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <ToolTip.Tip>
          <TextBlock Classes="p err" Text="{Binding FieldValidator.Error}" />
        </ToolTip.Tip>
      </TextBox>
      <Button Grid.Column="1" Content="..." Margin="5 0 0 0" Command="{Binding #Root.SelectFolder}" VerticalAlignment="Center" />
    </Grid>
    <Border Classes="thick err" IsVisible="{Binding FieldValidator.Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </Grid>
</UserControl>
