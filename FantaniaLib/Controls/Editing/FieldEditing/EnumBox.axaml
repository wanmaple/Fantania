<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="lib:IEditableField"
             x:Class="FantaniaLib.EnumBox">
  <UserControl.Resources>
    <lib:EnumType2OptionsConverter x:Key="Cvt_Enum2Options" />
  </UserControl.Resources>
  <Grid>
    <lib:OptionBox Options="{Binding FieldType, Converter={StaticResource Cvt_Enum2Options}}" Value="{Binding FieldValue, Mode=TwoWay}" />
    <Border Classes="thick err" IsVisible="{Binding FieldValidator.Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </Grid>
</UserControl>
