<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FantaniaLib.FileSelectBox"
             x:Name="Root">
  <Grid ColumnDefinitions="*,auto">
    <TextBox Grid.Column="0" Text="{Binding #Root.Path}" VerticalAlignment="Center" />
    <Button Grid.Column="1" Content="..." Padding="5" Margin="5 0 0 0" Command="{Binding #Root.PickFile}" VerticalAlignment="Center" />
  </Grid>
</UserControl>
