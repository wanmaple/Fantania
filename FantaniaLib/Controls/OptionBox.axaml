<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FantaniaLib.OptionBox"
             x:Name="Root">
  <ComboBox ItemsSource="{Binding #Root.Options}" SelectedValue="{Binding #Root.Value, Mode=TwoWay}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <ComboBox.DisplayMemberBinding>
      <Binding x:DataType="lib:Option" Path="Name" />
    </ComboBox.DisplayMemberBinding>
    <ComboBox.SelectedValueBinding>
      <Binding x:DataType="lib:Option" Path="Value" Mode="TwoWay" />
    </ComboBox.SelectedValueBinding>
  </ComboBox>
</UserControl>
