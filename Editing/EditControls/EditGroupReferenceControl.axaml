<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="{x:Type f:IEditableProperty}"
             x:Class="Fantania.EditGroupReferenceControl">
  <ComboBox ItemsSource="{ReflectionBinding EditInfo.Group, Converter={StaticResource Cvt_G2Ops}}" SelectedItem="{Binding EditValue, Mode=TwoWay}" DisplayMemberBinding="{ReflectionBinding Name}" MinWidth="300" />
</UserControl>
