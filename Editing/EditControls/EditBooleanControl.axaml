<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="30"
             x:Class="Fantania.EditBooleanControl"
             x:DataType="{x:Type f:IEditableProperty}">
  <CheckBox IsChecked="{Binding Path=EditValue, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center" />
</UserControl>
