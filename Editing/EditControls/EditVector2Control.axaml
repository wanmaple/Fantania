<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="30"
             x:DataType="{x:Type f:IEditableProperty}"
             x:Class="Fantania.EditVector2Control"
             x:Name="Root">
  <Grid ColumnDefinitions="*,*">
    <StackPanel Grid.Column="0" Orientation="Horizontal">
      <TextBlock Text="X" Margin="0 0 5 0" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding #Root.X}" Minimum="{ReflectionBinding EditInfo.XMinimum, Converter={x:Static f:NumberConverters.Float2Decimal}}" Maximum="{ReflectionBinding EditInfo.XMaximum, Converter={x:Static f:NumberConverters.Float2Decimal}}" Increment="{ReflectionBinding EditInfo.Increment}" ParsingNumberStyle="Float" FormatString="F2" />
    </StackPanel>
    <StackPanel Grid.Column="1" Orientation="Horizontal">
      <TextBlock Text="Y" Margin="0 0 5 0" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding #Root.Y}" Minimum="{ReflectionBinding EditInfo.YMinimum, Converter={x:Static f:NumberConverters.Float2Decimal}}" Maximum="{ReflectionBinding EditInfo.YMaximum, Converter={x:Static f:NumberConverters.Float2Decimal}}" Increment="{ReflectionBinding EditInfo.Increment}" ParsingNumberStyle="Float" FormatString="F2" />
    </StackPanel>
  </Grid>
</UserControl>
