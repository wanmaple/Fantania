<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             xmlns:m="using:Fantania.Models"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="30"
             x:DataType="{x:Type f:IEditableProperty}"
             x:Class="Fantania.EditEnumControl">
  <UserControl.Resources>
    <f:EnumInfo x:Key="Obj_EnumInfo" />
  </UserControl.Resources>
  <ComboBox SelectedItem="{Binding EditValue, Mode=TwoWay, Converter={StaticResource Cvt_EnumVal2Str}, ConverterParameter={StaticResource Obj_EnumInfo}}" ItemsSource="{Binding Converter={StaticResource Cvt_EP2EnumList}}" HorizontalAlignment="Stretch" />
</UserControl>
