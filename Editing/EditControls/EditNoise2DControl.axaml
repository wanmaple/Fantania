<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             xmlns:v="using:Fantania.Views"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="150"
             x:DataType="{x:Type f:IEditableProperty}"
             x:Class="Fantania.EditNoise2DControl"
             x:Name="Root">
  <Grid RowDefinitions="auto,auto,*">
    <f:PreviewCanvas x:Name="preview" Grid.Row="0" ColorBufferWidth="256" ColorBufferHeight="256" Width="256" Height="256" Margin="10" />
    <f:EditEnumControl Grid.Row="1" DataContext="{Binding #Root.NoiseType}" />
    <v:PropertiesView x:Name="pvNoise" Grid.Row="2" IsHeaderVisible="False" />
  </Grid>
</UserControl>
