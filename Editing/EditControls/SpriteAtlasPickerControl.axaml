<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="30"
             x:DataType="{x:Type f:IEditableProperty}"
             x:Class="Fantania.SpriteAtlasPickerControl"
             x:Name="Root">
  <Grid ColumnDefinitions="*,auto">
    <TextBox Grid.Column="0" Text="{Binding EditValue}" MinWidth="200" VerticalAlignment="Center" IsReadOnly="True" />
    <Button Grid.Column="1" Content="..." Command="{Binding #Root.PickSpriteAtlas}" Margin="5 0 0 0" VerticalAlignment="Center" />
  </Grid>
</UserControl>
