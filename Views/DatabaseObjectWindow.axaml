<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:f="using:Fantania"
        xmlns:v="using:Fantania.Views"
        xmlns:vm="using:Fantania.ViewModels"
        xmlns:lang="using:Fantania.Localization"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="480"
        x:Class="Fantania.Views.DatabaseObjectWindow"
        x:DataType="{x:Type vm:DatabaseObjectViewModel}"
        x:Name="Root" Width="640" Height="640">
  <Grid RowDefinitions="auto,*,auto" Margin="5">
    <TextBlock Grid.Row="0" Classes="h2" Text="{x:Static lang:Resources.PropertyPanelHeader}" />
    <ScrollViewer Grid.Row="1" Margin="0 5 0 0">
      <v:PropertiesView x:Name="properties" DataContext="{Binding CurrentObject, Converter={StaticResource Cvt_Ob2PropsVM}}" />
    </ScrollViewer>
    <StackPanel Grid.Row="2" Orientation="Horizontal" FlowDirection="RightToLeft">
      <Button Classes="l" IsVisible="{Binding Functionality, Converter={x:Static f:NumberConverters.IntegerEqual}, ConverterParameter=0}" Content="{x:Static lang:Resources.ButtonTextAdd}" Command="{Binding #Root.AddObject}" HorizontalAlignment="Right" />
      <TextBlock x:Name="txtErr" Foreground="IndianRed" VerticalAlignment="Center" Margin="10 0 0 0" />
    </StackPanel>
  </Grid>
</Window>
