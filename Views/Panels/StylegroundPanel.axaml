<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             xmlns:m="using:Fantania.Models"
             xmlns:lang="using:Fantania.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="{x:Type m:Workspace}"
             x:Class="Fantania.Views.StylegroundPanel"
             x:Name="Root">
  <Grid RowDefinitions="auto,auto,*" Margin="10">
    <Button Grid.Row="0" Content="{x:Static lang:Resources.ButtonTextOpenEditor}" Command="{Binding #Root.OpenEditor}" />
  </Grid>
</UserControl>
