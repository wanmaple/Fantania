<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:f="using:Fantania"
        xmlns:v="using:Fantania.Views"
        xmlns:vm="using:Fantania.ViewModels"
        xmlns:lang="using:Fantania.Localization"
        Icon="/Assets/sg_icon.ico"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Fantania.Views.StylegroundEditorWindow"
        x:DataType="{x:Type vm:StylegroundEditorViewModel}"
        Title="{x:Static lang:Resources.TitleStylegroundEditor}">
  <Window.KeyBindings>
    <KeyBinding Command="{Binding UndoCommand}" Gesture="Ctrl+Z" />
    <KeyBinding Command="{Binding RedoCommand}" Gesture="Ctrl+Shift+Z" />
  </Window.KeyBindings>
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
      <TextBlock Classes="h2" Text="{Binding Workspace.CurrentLevel.Group, StringFormat='{}Current level group: {0}'}" />
    </StackPanel>
    <ContentControl>
      <v:StylegroundEditorView />
    </ContentControl>
  </DockPanel>
</Window>
