<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:f="using:Fantania"
        xmlns:lib="using:FantaniaLib"
        xmlns:vm="using:Fantania.ViewModels"
        xmlns:lang="using:Fantania.Localization"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Fantania.Views.ExportView"
        x:DataType="vm:ExportViewModel"
        Title="{x:Static lang:Resources.H_ExportTo}"
        SizeToContent="WidthAndHeight" CanResize="False"
        WindowStartupLocation="CenterScreen">
  <Grid RowDefinitions="*,auto">
    <ScrollViewer Grid.Row="0" Margin="5" MaxHeight="640">
      <lib:ObjectEditView x:Name="oevObj">
        <lib:ObjectEditView.EditableFields>
          <MultiBinding Converter="{StaticResource Cvt_Obj2Groups}">
            <Binding Path="Context.ExportSettings" />
            <Binding Path="Workspace" />
          </MultiBinding>
        </lib:ObjectEditView.EditableFields>
      </lib:ObjectEditView>
    </ScrollViewer>
    <StackPanel Grid.Row="1" Orientation="Horizontal" FlowDirection="RightToLeft" Margin="5">
      <Button Content="{x:Static lang:Resources.BT_Export}" />
    </StackPanel>
  </Grid>
</Window>
