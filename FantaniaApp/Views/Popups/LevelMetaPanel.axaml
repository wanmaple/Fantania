<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             xmlns:v="using:Fantania.Views"
             xmlns:vm="using:Fantania.ViewModels"
             xmlns:lang="using:Fantania.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:LevelViewModel"
             x:Class="Fantania.Views.LevelMetaPanel">
  <UserControl.Resources>
  </UserControl.Resources>
  <Grid Margin="5">
    <lib:ObjectEditView>
      <lib:ObjectEditView.EditableFields>
        <MultiBinding Converter="{StaticResource Cvt_Obj2Groups}">
          <Binding Path="Workspace.LevelModule.Metadata" />
          <Binding Path="Workspace" />
        </MultiBinding>
      </lib:ObjectEditView.EditableFields>
    </lib:ObjectEditView>
  </Grid>
</UserControl>
