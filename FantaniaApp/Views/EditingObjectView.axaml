<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             xmlns:f="using:Fantania"
             xmlns:vm="using:Fantania.ViewModels"
             xmlns:lang="using:Fantania.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:PlacementViewModel"
             x:Class="Fantania.Views.EditingObjectView">
  <Design.DataContext>
    <vm:PlacementViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="auto,*">
    <TextBlock Classes="h2" Grid.Row="0" Text="{x:Static lang:Resources.H_Properties}" />
    <ScrollViewer Grid.Row="1">
      <lib:ObjectEditView EditableFields="{Binding SelectedPlacement, Converter={StaticResource Cvt_Obj2Groups}}" />
    </ScrollViewer>
  </Grid>
</UserControl>
