<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:lib="using:FantaniaLib"
        xmlns:vm="using:Fantania.ViewModels"
        xmlns:lang="using:Fantania.Localization"
        x:Class="Fantania.Views.NoiseGeneratorView"
        x:DataType="vm:NoiseGeneratorViewModel"
        Title="{x:Static lang:Resources.H_NoiseGenerator}" WindowStartupLocation="CenterScreen" 
        SizeToContent="WidthAndHeight" CanResize="False">
  <Window.Resources>
    <lib:Object2MemberConverter x:Key="Cvt_Member" />
  </Window.Resources>
  <Grid RowDefinitions="auto,auto,*" ColumnDefinitions="auto,*" Margin="10">
    <TextBlock Classes="h2" Grid.Row="0" Grid.ColumnSpan="2" Text="{x:Static lang:Resources.H_NoiseGenerator}" HorizontalAlignment="Left" VerticalAlignment="Center" />
    <ScrollViewer x:Name="svFields" Grid.Row="1" Grid.Column="0" Margin="0 10 0 0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="400">
      <lib:ObjectEditView>
        <lib:ObjectEditView.EditableFields>
          <MultiBinding Converter="{StaticResource Cvt_Objs2Groups}">
            <Binding Path="Noise" />
            <Binding Path="Noise.NoiseArguments" />
            <Binding Path="Noise.CompositorArguments" />
            <Binding Path="Workspace" />
          </MultiBinding>
        </lib:ObjectEditView.EditableFields>
      </lib:ObjectEditView>
    </ScrollViewer>
    <Button Grid.Row="2" Grid.Column="0" Width="100" Content="{x:Static lang:Resources.CM_Save}" Command="{Binding SaveNoiseCommand}" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="0 10 0 0" />
    <ScrollViewer Grid.Row="1" Grid.Column="1" MaxWidth="{Binding #svFields.Bounds.Height}" MaxHeight="{Binding #svFields.Bounds.Height}" Margin="10 10 0 0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- Preview Image -->
        <Image Source="{Binding NoiseBitmap}" Width="{Binding Noise.Size, Converter={StaticResource Cvt_Member}, ConverterParameter=X}" Height="{Binding Noise.Size, Converter={StaticResource Cvt_Member}, ConverterParameter=Y}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <!-- Loading Indicator Overlay -->
        <StackPanel IsVisible="{Binding IsGenerating}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
          <ProgressBar IsIndeterminate="True" Width="150" Height="4" />
        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Window>
