<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="150"
        x:Class="Fantania.Views.PendingView"
        WindowStartupLocation="CenterOwner" CanResize="False" SystemDecorations="None"
        SizeToContent="WidthAndHeight" ShowInTaskbar="False" Background="#80000000">
  <Grid Margin="16">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
      <Canvas Width="48" Height="48">
        <Ellipse x:Name="spinner" Width="48" Height="48"
           StrokeThickness="4"
           Stroke="#FFFFFFFF"
           StrokeDashArray="2,3"
           RenderTransformOrigin="24,24">
          <Ellipse.RenderTransform>
            <RotateTransform Angle="0" />
          </Ellipse.RenderTransform>
        </Ellipse>
      </Canvas>
    </Grid>
  </Grid>
</Window>
