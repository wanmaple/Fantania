<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lib="using:FantaniaLib"
             xmlns:vm="using:Fantania.ViewModels"
             xmlns:lang="using:Fantania.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:LevelViewModel"
             x:Class="Fantania.Views.ToolbarView">
  <Design.DataContext>
    <vm:LevelViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="auto,*">
    <DockPanel Grid.Row="0" HorizontalAlignment="Stretch">
      <TextBlock DockPanel.Dock="Left" Classes="p" IsVisible="{Binding Workspace.IsModified}" Text="*" Foreground="LightGreen" />
      <TextBlock DockPanel.Dock="Left" Classes="p" Margin="5 0 0 0">
        <TextBlock.Text>
          <MultiBinding StringFormat="{}{0}: {1}">
            <Binding Source="{x:Static lang:Resources.H_CurrentWorkspace}" />
            <Binding Path="Workspace.RootFolder" />
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
      <TextBlock DockPanel.Dock="Right" Classes="p" Text="{Binding Workspace.EditorModule.FPS, StringFormat={}FPS: {0}}" HorizontalAlignment="Right" VerticalAlignment="Center" />
    </DockPanel>
    <TextBlock Grid.Row="1" Classes="p" Text="{Binding Workspace.EditorModule.MouseWorldPosition}" />
  </Grid>
</UserControl>
