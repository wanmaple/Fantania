<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:f="using:Fantania"
             xmlns:lib="using:FantaniaLib"
             xmlns:m="using:Fantania.Models"
             xmlns:v="using:Fantania.Views"
             xmlns:vm="using:Fantania.ViewModels"
             xmlns:lang="using:Fantania.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:WorkspaceViewModel"
             x:Class="Fantania.Views.WorkspaceView">
  <Design.DataContext>
    <vm:WorkspaceViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="auto,2*,auto,*" ColumnDefinitions="2*,auto,*">
    <Border Classes="thin s1" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2">
      <v:LevelView DataContext="{Binding LevelViewModel}" Margin="5" />
    </Border>
    <GridSplitter Grid.Row="2" Grid.Column="0" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Height="1" />
    <Border Classes="thin s1" Grid.Row="3" Grid.Column="0">
      <v:LogView DataContext="{Binding LogViewModel}" Margin="5" />
    </Border>
    <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="4" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Width="1" />
    <Grid Classes="thin s1" Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" RowDefinitions="*,auto,1.5*">
      <Border Classes="thin s1" Grid.Row="0">
        <v:PlacementView DataContext="{Binding PlacementViewModel}" Margin="5" />
      </Border>
      <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Height="1" />
      <Border Classes="thin s1" Grid.Row="2">
        <v:EditingObjectView DataContext="{Binding PlacementViewModel}" Margin="5" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
